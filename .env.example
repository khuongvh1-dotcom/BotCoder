# Copy to .env and fill in. NEVER commit .env.

# --- Claude auth: choose ONE ---

# Option A (recommended for Pro/Max plans): subscription OAuth token.
# Generate once with the Claude Code CLI:  claude setup-token
# Usage counts against your Claude plan, not pay-as-you-go API credits.
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: pay-as-you-go API key from https://platform.claude.com
# NOTE: if BOTH are set, ANTHROPIC_API_KEY wins (uses API credits, not your plan).
# Leave this blank to use the subscription token above.
ANTHROPIC_API_KEY=

# --- GitHub ---
# Optional: GitHub token. Prefer using `gh auth login` instead.
# If set, needs scopes: repo, workflow.
GITHUB_TOKEN=
